{
  "name": "notepadpp-mcp",
  "version": "0.2.0",
  "type": "server",
  "runtime": "python",
  "entry_point": "src/notepadpp_mcp/server.py",
  "dependencies": [
    "fastmcp>=3.1.0,<4",
    "httpx>=0.27.0",
    "fastapi>=0.115.0",
    "uvicorn[standard]>=0.27.0",
    "psutil>=5.9.0",
    "pydantic>=2.0.0",
    "mcp>=1.0.0,<2.0.0",
    "requests>=2.31.0",
    "structlog>=23.0.0",
    "pywin32>=311 ; sys_platform == 'win32'"
  ],
  "build": {
    "include": [
      "src/**/*",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "tests/",
      ".git/",
      "__pycache__/",
      "*.pyc",
      ".venv/",
      "dist/",
      "build/",
      "target/",
      "docs/",
      "scripts/",
      "web_sota/"
    ]
  },
  "scripts": {
    "build": "mcpb build",
    "pack": "mcpb pack . dist/notepadpp-mcp.mcpb",
    "test": "python -m pytest"
  }
}
